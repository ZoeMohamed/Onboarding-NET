@TaskManagement.API_HostAddress = https://localhost:7187
@userToken = 
@adminToken = 
@managerToken = 
@taskId = 

### Register New User
POST {{TaskManagement.API_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "newuser",
  "email": "newuser@local.dev",
  "password": "NewUser@123!",
  "confirmPassword": "NewUser@123!"
}

### Login Seed User
POST {{TaskManagement.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "user",
  "password": "User@123!"
}

### Login Seed Admin
POST {{TaskManagement.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "Admin@123!"
}

### Login Seed Manager
POST {{TaskManagement.API_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "manager",
  "password": "Manager@123!"
}

### Get All Tasks (Auth required)
GET {{TaskManagement.API_HostAddress}}/api/tasks
Authorization: Bearer {{userToken}}

### Create Task
POST {{TaskManagement.API_HostAddress}}/api/tasks
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "title": "Sample Task from HTTP file",
  "description": "Day 6-7 flow",
  "priority": "High"
}

### Get Task By Id
GET {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}
Authorization: Bearer {{userToken}}

### Update Task
PUT {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "title": "Sample Task Updated",
  "priority": "Medium"
}

### Start Task
PATCH {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}/start
Authorization: Bearer {{userToken}}

### Complete Task
PATCH {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}/complete
Authorization: Bearer {{userToken}}

### Approve Task (Admin or Manager)
PATCH {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}/approve
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "note": "Approved from api.http"
}

### Reject Task (Admin or Manager)
PATCH {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}/reject
Authorization: Bearer {{managerToken}}
Content-Type: application/json

{
  "note": "Rejected from api.http"
}

### Get Approval Logs
GET {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}/approvals
Authorization: Bearer {{userToken}}

### Delete Task
DELETE {{TaskManagement.API_HostAddress}}/api/tasks/{{taskId}}
Authorization: Bearer {{userToken}}
